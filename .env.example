# Supabase (browser-safe — used by lib/supabase.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — server only (Stripe webhook updates orders; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Resend (contact form — server only)
RESEND_API_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=

# Canonical public URL — used when the Stripe webhook calls `/api/send-order-confirmation` on this deploy.
NEXT_PUBLIC_SITE_URL=

# Bearer token shared by the webhook route and `/api/send-order-confirmation`. Generate a random string; never expose client-side.
INTERNAL_ORDER_EMAIL_SECRET=

# Optional: fallback shared secret used by outbound internal APIs (see lib/send-order-confirmation-email.ts)
# INTERNAL_API_SECRET=
